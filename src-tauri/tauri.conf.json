{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ScreenBlocker",
  "version": "0.1.0",
  "identifier": "com.shudiptot.screenblocker",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "ScreenBlocker",
        "width": 1000,
        "height": 740,
        "minWidth": 720,
        "minHeight": 560,
        "resizable": true,
        "visible": false,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "Stand-up & stretch break enforcer",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ]
  }
}
